# PostgreSQL connection string
# e.g. Railway: postgresql://user:password@host:port/dbname
DATABASE_URL=

# Secret key used to sign JWTs — use a long random string in production
JWT_SECRET=

# Port the Express server listens on (default: 3000)
PORT=3000

# Resend API key for sending password reset emails (get one at resend.com)
RESEND_API_KEY=

# Public base URL of the app — used in reset email links
# e.g. https://brandbae.up.railway.app (no trailing slash)
BASE_URL=
